# Configuración de deploy_to_ha.sh — COPIA este fichero a scripts/deploy.env y rellénalo.
# scripts/deploy.env está gitignoreado (contiene tu host/IP); esta plantilla sí se versiona.

# IP o hostname de tu Home Assistant (obligatorio)
HA_SSH_HOST=homeassistant.local

# Usuario SSH (add-on SSH de HAOS: normalmente "root"; add-on community suele usar "hassio")
HA_SSH_USER=root

# Puerto SSH (22 por defecto; el add-on "SSH & Web Terminal" de la community usa 22222)
HA_SSH_PORT=22

# Directorio de config de HA (HAOS/Supervised: /config)
HA_CONFIG_DIR=/config

# Opciones extra para ssh (ej. una clave concreta, o desactivar el agente de identidad)
# HA_SSH_OPTS="-o IdentityAgent=none"

# Pon "sudo" si tu usuario SSH NO es dueño de /config (típico: entras como hassio pero
# /config es de root) y tiene sudo sin contraseña. Déjalo vacío si entras como root.
# HA_SUDO=sudo
